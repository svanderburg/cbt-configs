#!/bin/bash -e

source $cbtFunctionsDir/deployDesktopSourcePackage
source $cbtBaseDir/settings/slackware-8.0

name=tilem
version=0.925r2
license=LGPLv2.1
group=Emulators
description="TI 8x emulator"
src="t/tilem/${name}_0-925r2.tar.gz"

desktopName="TilEm"
category=Emulators
exec=tilem
comment="TI 8x emulator"

showLongDescription()
{
    cat << "EOF"

TilEm is an emulator and debugger for Texas Instruments Z80-based graphing
calculators. It can emulate any of the following calculator models: TI-73,
TI-73 Explorer, TI-76.fr, TI-81, TI-82, TI-82 STATS / TI-82 STATS.fr, TI-83,
TI-83 Plus, TI-83 Plus Silver Edition, TI-83 Plus.fr, TI-84 Plus, TI-84 Plus
Silver Edition, TI-84 pocket.fr, TI-85, TI-86.
EOF
}

buildPhase()
{
    make
}

installPhase()
{
    make install
}

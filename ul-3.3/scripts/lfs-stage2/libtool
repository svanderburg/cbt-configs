#!/bin/bash -e

source $cbtFunctionsDir/deployStage2SourcePackage
source $cbtBaseDir/settings/lfs-settings

name=libtool
version=1.4.2
group=lfs-stage2
description="GNU Libtool"
license=GPLv2
src="l/libtool/$name-$version.tar.gz"

showLongDescription()
{
    cat << "EOF"
GNU Libtool is a generic library support script that hides the complexity of
using shared libraries behind a consistent, portable interface.
EOF
}

buildPhase()
{
    ./configure --prefix=/usr
    make
}

installPhase()
{
    make install
}
